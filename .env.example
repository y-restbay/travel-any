# Backend
DATABASE_URL=sqlite:///./wanderbot.db

# RAG embedding provider.
# Leave as "hash" for local fallback, or switch to "openai" / "gemini".
RAG_EMBEDDING_PROVIDER=hash
RAG_EMBEDDING_MODEL=
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_TIMEOUT=20

# OpenAI-compatible example:
# RAG_EMBEDDING_PROVIDER=openai
# RAG_EMBEDDING_MODEL=text-embedding-3-small
# RAG_EMBEDDING_API_KEY=sk-...
# RAG_EMBEDDING_BASE_URL=

# Gemini example:
# RAG_EMBEDDING_PROVIDER=gemini
# RAG_EMBEDDING_MODEL=models/gemini-embedding-001
# RAG_EMBEDDING_API_KEY=...

# 和风天气（QWeather）API Key，用于天气查询工具 get_weather
# 在 https://console.qweather.com 申请免费订阅版 KEY
QWEATHER_KEY=
# 可选：覆盖默认 API 主机。和风从 2026 年起逐步关停公共域名，
# 届时请把开发者控制台分配的私有 API Host 填进来。
# QWEATHER_HOST=devapi.qweather.com
# QWEATHER_GEO_HOST=geoapi.qweather.com

# Tavily Search API Key，用于实时旅游信息搜索工具 search_realtime_travel_info
# 在 https://tavily.com 申请；后台工具配置留空时读取此环境变量
TAVILY_API_KEY=

# 阿里云百炼云知识库 Retrieve 纯检索接口（保留高级接入方式）
# 云端完成召回+重排，结果注入本系统大模型。AK/SK 在阿里云 RAM 控制台创建；
# WorkspaceId / IndexId 在百炼控制台获取。
BAILIAN_ACCESS_KEY_ID=
BAILIAN_ACCESS_KEY_SECRET=
BAILIAN_WORKSPACE_ID=
BAILIAN_INDEX_ID=
# 可选：覆盖默认接入点（默认 bailian.cn-beijing.aliyuncs.com）
# BAILIAN_ENDPOINT=bailian.cn-beijing.aliyuncs.com

# 阿里云百炼应用通道（当前聊天框「云知识库」开关优先使用）
# 使用 DashScope sk 调用百炼应用，由百炼应用自行选择其绑定的知识库并直接生成回答。
DASHSCOPE_API_KEY=
DASHSCOPE_WORKSPACE_ID=
APP_ID=
# 兼容别名，也可以使用 BAILIAN_APP_API_KEY / BAILIAN_APP_WORKSPACE_ID / BAILIAN_APP_ID。
# 可选：默认 https://dashscope.aliyuncs.com/api/v1
# BAILIAN_APP_BASE_URL=https://dashscope.aliyuncs.com/api/v1
