# Backend
DATABASE_URL=sqlite:///./wanderbot.db

# RAG embedding provider.
# Leave as "hash" for local fallback, or switch to "openai" / "gemini".
RAG_EMBEDDING_PROVIDER=hash
RAG_EMBEDDING_MODEL=
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_TIMEOUT=20

# OpenAI-compatible example:
# RAG_EMBEDDING_PROVIDER=openai
# RAG_EMBEDDING_MODEL=text-embedding-3-small
# RAG_EMBEDDING_API_KEY=sk-...
# RAG_EMBEDDING_BASE_URL=

# Gemini example:
# RAG_EMBEDDING_PROVIDER=gemini
# RAG_EMBEDDING_MODEL=models/gemini-embedding-001
# RAG_EMBEDDING_API_KEY=...

# 和风天气（QWeather）API Key，用于天气查询工具 get_weather
# 在 https://console.qweather.com 申请免费订阅版 KEY
QWEATHER_KEY=
# 可选：覆盖默认 API 主机。和风从 2026 年起逐步关停公共域名，
# 届时请把开发者控制台分配的私有 API Host 填进来。
# QWEATHER_HOST=devapi.qweather.com
# QWEATHER_GEO_HOST=geoapi.qweather.com
